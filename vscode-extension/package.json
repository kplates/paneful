{
  "name": "paneful-vscode",
  "displayName": "Paneful",
  "description": "Send open file paths to the focused Paneful terminal",
  "version": "0.1.0",
  "publisher": "kplates",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "paneful.sendOpenFiles",
        "title": "Paneful: Send open file paths"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
